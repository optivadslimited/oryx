# Database (PostgreSQL — use Neon, Supabase, or local)
DATABASE_URL="postgresql://user:password@host:5432/oryx?schema=public"

# Admin auth (JWT)
JWT_SECRET="your-secret-at-least-32-chars-long"

# Optional: seed admin user (run npm run db:seed)
# ADMIN_EMAIL=admin@oryxeyewear.com
# ADMIN_PASSWORD=your-secure-password

# Optional: delivery webhook (for API updates from delivery company)
# DELIVERY_WEBHOOK_SECRET=your-webhook-secret
